# --- Build artefacts -------------------------------------------------

# Per-station JSON files generated by resolver/build.py
resolver/s[0-9]*

# --- Per-user config (NEVER commit) ----------------------------------

# Your personal station list — copy stations.example.json to this and edit
resolver/stations.json

# Backup directories produced by scripts/backup-presets.sh
soundtouch-backup-*/

# --- Planning + scratch (intentionally local-only) -------------------

# We plan with Claude / scratch ideas in these locations and DO NOT
# commit them. Anything not in the repo's tracked files goes here.
planning/
notes/
scratch/
TODO.md
NOTES.md
IDEAS.md
*.draft.md
*.scratch.md
*.local
*.local.md
*.bak
*.bak-*
.claude/

# Claude Design handoff bundle for the admin UI — kept locally next to
# admin/PLAN.md as a styling reference, never committed.
admin/design-mockup/

# --- Editor / OS junk ------------------------------------------------

.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Python ----------------------------------------------------------

__pycache__/
*.pyc
.venv/
venv/

# --- Node ------------------------------------------------------------

# Dev-only: admin/test/ uses @xmldom/xmldom for fixture-driven WS tests.
# Lockfile is committed; node_modules is reinstallable via `npm ci`.
node_modules/

# --- Playwright e2e suite (admin/e2e/) -------------------------------

# The e2e suite under admin/e2e/ is a sub-package; its node_modules and
# generated artefacts must never be committed. The suite itself
# (specs, config, fixtures, README, package.json) IS committed.
admin/e2e/node_modules/
admin/e2e/test-results/
admin/e2e/playwright-report/
admin/e2e/.playwright/
