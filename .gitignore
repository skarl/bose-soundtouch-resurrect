# --- Build artefacts -------------------------------------------------

# Per-station JSON files generated by resolver/build.py
resolver/s[0-9]*

# --- Per-user config (NEVER commit) ----------------------------------

# Your personal station list — copy stations.example.json to this and edit
resolver/stations.json

# Backup directories produced by scripts/backup-presets.sh
soundtouch-backup-*/

# --- Planning + scratch (intentionally local-only) -------------------

