#!/bin/sh
#
# presets — list + atomic save+store.
#
# GET  /cgi-bin/api/v1/presets         → 6 slots, JSON envelope
# POST /cgi-bin/api/v1/presets/:slot   → write resolver JSON + storePreset
#
# GET parses the speaker's <presets> XML into 6-slot ordered array.
# Empty slots are emitted as {slot:N, empty:true}. Per-slot extraction
# is best-effort awk — if a slot's XML can't be parsed cleanly we
# return it as empty rather than fail the whole envelope.
#
# POST validates {id, slot, name, kind, json} from the JSON body, then:
#   1. Writes `json` atomically to /mnt/nv/.../<id>.tmp + mv to <id>.
#   2. Calls speaker /storePreset?id=<slot> with the
#      <preset><ContentItem ...><itemName>...</itemName></ContentItem></preset>
#      shape (name XML-escaped).
#   3. Returns the now-current /presets list as `data`.
# No rollback on /storePreset failure: a failed /storePreset leaves
# the speaker's preset list unchanged; the CGI returns the current
# list as `data` so the caller sees ground truth and can retry.
#
# Envelope + CSRF guard live in admin/cgi-bin/lib/playback.sh, shared
# with /play and /preview.
#
# busybox-shell only — no bash-isms, no jq. Must pass shellcheck
# under --severity=warning.

set -u

# shellcheck source=../../lib/playback.sh
. "$(dirname "$0")/../../lib/playback.sh"

# Extract the text content of the FIRST occurrence of <tag>...</tag>
# from stdin. Single-line tags only — fine for the speaker's output.
# Decodes the five XML entities so consumers don't need to. Local to
# this CGI because no other playback CGI consumes the speaker's XML.
xml_text() {
    sed -n "s|.*<${1}[^>]*>\\([^<]*\\)</${1}>.*|\\1|p" \
        | head -n 1 \
        | sed \
            -e 's/&lt;/</g' \
            -e 's/&gt;/>/g' \
            -e 's/&quot;/"/g' \
            -e "s/&apos;/'/g" \
            -e 's/&amp;/\&/g'
}

# Fetch /presets from the speaker, parse, and emit the JSON envelope on
# stdout. Returns 0 on success, non-zero on transport failure (caller
# is responsible for emitting an error envelope in that case). Uses
# unique tmpfiles per invocation so it's safe to call from any handler;
# cleans up before returning rather than relying on a trap that would
# clobber the caller's.
fetch_and_emit_presets() {
    fp_body="$PLAYBACK_TMPDIR/presets.$$.body"

    # busybox wget exits 0 on 2xx and nonzero on 4xx/5xx/network error,
    # so we don't need `-S` to inspect headers (and busybox doesn't
    # support that flag anyway).
    if ! wget -q -O "$fp_body" "${PLAYBACK_SPEAKER_BASE}/presets"; then
        rm -f "$fp_body"
        return 1
    fi

    # Flatten newlines and pipe straight into a single awk that emits
    # the full envelope. One fork instead of ~80 (the previous
    # implementation forked sed/awk per-attribute per-slot, which on
    # the speaker's CPU added up to several seconds per request).
    tr '\n' ' ' <"$fp_body" | awk '
        BEGIN {
            # XML entity decoder pairs.
            ek[1]="&lt;";   ev[1]="<"
            ek[2]="&gt;";   ev[2]=">"
            ek[3]="&quot;"; ev[3]="\""
            ek[4]="&apos;"; ev[4]="\x27"
            ek[5]="&amp;";  ev[5]="&"
        }
        function decode(s,    i) {
            for (i = 1; i <= 5; i++) gsub(ek[i], ev[i], s)
            return s
        }
        # Pull attribute `name` off the first <tag ...> in s.
        function attr(s, tag, name,    re, rest, end) {
            re = "<" tag "[^>]* " name "=\""
            if (match(s, re) == 0) return ""
            rest = substr(s, RSTART + RLENGTH)
            end = index(rest, "\"")
            if (end == 0) return ""
            return substr(rest, 1, end - 1)
        }
        # Pull the text content of the first <tag>...</tag> in s.
        # Returns the entity-decoded text.
        function text(s, tag,    re, rest, end) {
            re = "<" tag "[^>]*>"
            if (match(s, re) == 0) return ""
            rest = substr(s, RSTART + RLENGTH)
            end = index(rest, "</" tag ">")
            if (end == 0) return ""
            return decode(substr(rest, 1, end - 1))
        }
        # JSON-escape: handle the must-escape characters one at a time
        # rather than gsub-ing — gsub replacement-string semantics for
        # backslashes are awkward across awk implementations, so we walk
        # the string instead. Inputs are short (preset names + URLs).
        function jesc(s,    i, n, c, out) {
            out = ""; n = length(s)
            for (i = 1; i <= n; i++) {
                c = substr(s, i, 1)
                if (c == "\\")      out = out "\\\\"
                else if (c == "\"") out = out "\\\""
                else if (c == "\n") out = out "\\n"
                else if (c == "\r") out = out "\\r"
                else if (c == "\t") out = out "\\t"
                else                out = out c
            }
            return out
        }
        function emit_empty(slot,    sep) {
            sep = (slot == 1 ? "" : ",")
            printf "%s{\"slot\":%d,\"empty\":true}", sep, slot
        }
        {
            body = $0
            printf "{\"ok\":true,\"data\":["
            for (n = 1; n <= 6; n++) {
                pat = "<preset id=\"" n "\""
                start = index(body, pat)
                if (start == 0) { emit_empty(n); continue }
                rest = substr(body, start)
                end = index(rest, "</preset>")
                if (end == 0)   { emit_empty(n); continue }
                block = substr(rest, 1, end + length("</preset>") - 1)

                src  = attr(block, "ContentItem", "source")
                typ  = attr(block, "ContentItem", "type")
                loc  = attr(block, "ContentItem", "location")
                name = text(block, "itemName")
                art  = text(block, "containerArt")

                if (src == "" && loc == "" && name == "") {
                    emit_empty(n); continue
                }
                sep = (n == 1 ? "" : ",")
                printf "%s{\"slot\":%d,\"source\":\"%s\",\"type\":\"%s\",\"location\":\"%s\",\"itemName\":\"%s\",\"art\":\"%s\"}", \
                    sep, n, jesc(src), jesc(typ), jesc(loc), jesc(name), jesc(art)
            }
            printf "]}\n"
        }
    '
    rm -f "$fp_body"
    return 0
}

# Match against ^s[0-9]+$ — id sanity. Returns 0 on match, 1 on mismatch.
is_valid_id() {
    case "$1" in
        s) return 1 ;;
        s*)
            tail=${1#s}
            case "$tail" in
                ''|*[!0-9]*) return 1 ;;
                *) return 0 ;;
            esac
            ;;
        *) return 1 ;;
    esac
}

# Match an integer 1..6. Returns 0 on match.
is_valid_slot() {
    case "$1" in
        1|2|3|4|5|6) return 0 ;;
        *) return 1 ;;
    esac
}

# CORS preflight: respond and exit before doing any work.
if handle_cors_preflight 'GET, POST, OPTIONS'; then exit 0; fi

handle_get() {
    if fetch_and_emit_presets >"$PLAYBACK_TMPDIR/presets-out.$$"; then
        emit_ok_headers 'GET, POST, OPTIONS'
        cat "$PLAYBACK_TMPDIR/presets-out.$$"
        rm -f "$PLAYBACK_TMPDIR/presets-out.$$"
    else
        rm -f "$PLAYBACK_TMPDIR/presets-out.$$"
        emit_error '502 Bad Gateway' UPSTREAM_UNREACHABLE \
            "speaker /presets fetch failed"
    fi
}

handle_post() {
    # Same Origin+Referer guard as the speaker CGI.
    csrf_guard || return 0

    # PATH_INFO is /1 .. /6 (the slot).
    pi="${PATH_INFO:-}"
    path_slot="${pi#/}"
    if ! is_valid_slot "$path_slot"; then
        emit_error '400 Bad Request' INVALID_SLOT \
            "slot must be in PATH_INFO as /1..6"
        return 0
    fi

    body_file="$PLAYBACK_TMPDIR/presets-req.$$.body"
    # shellcheck disable=SC2064
    trap "rm -f '$body_file'" EXIT INT TERM
    slurp_body "$body_file"

    body_id=$(json_string_field id <"$body_file")
    body_slot=$(json_number_field slot <"$body_file")
    body_kind=$(json_string_field kind <"$body_file")
    body_name=$(json_string_field name <"$body_file")
    body_art=$(json_string_field art <"$body_file")
    body_json=$(json_object_field <"$body_file")

    if [ -z "$body_id" ] || ! is_valid_id "$body_id"; then
        emit_error '400 Bad Request' INVALID_ID \
            "id must match ^s[0-9]+\$"
        return 0
    fi
    if [ -z "$body_slot" ] || ! is_valid_slot "$body_slot"; then
        emit_error '400 Bad Request' INVALID_SLOT \
            "slot must be 1..6"
        return 0
    fi
    if [ "$body_slot" != "$path_slot" ]; then
        emit_error '400 Bad Request' SLOT_MISMATCH \
            "path slot does not equal body slot"
        return 0
    fi
    if [ "$body_kind" != "playable" ]; then
        emit_error '400 Bad Request' INVALID_KIND \
            'kind must be the literal playable'
        return 0
    fi
    if [ -z "$body_name" ]; then
        emit_error '400 Bad Request' INVALID_NAME \
            "name must be a non-empty string"
        return 0
    fi
    if [ -z "$body_json" ]; then
        emit_error '400 Bad Request' INVALID_JSON \
            "json field missing or unparseable"
        return 0
    fi

    # Atomic write: tmp + mv on the same filesystem.
    target="${PLAYBACK_RESOLVER_DIR}/${body_id}"
    target_tmp="${target}.tmp"
    mkdir -p "$PLAYBACK_RESOLVER_DIR" 2>/dev/null || true

    if ! printf '%s' "$body_json" >"$target_tmp" 2>/dev/null; then
        emit_error '500 Internal Server Error' WRITE_FAILED \
            "couldn't write resolver JSON"
        return 0
    fi
    if ! mv "$target_tmp" "$target" 2>/dev/null; then
        rm -f "$target_tmp"
        emit_error '500 Internal Server Error' RENAME_FAILED \
            "couldn't move resolver JSON into place"
        return 0
    fi

    # Build the storePreset XML body. The speaker keys preset metadata
    # off ContentItem.location, which is the resolver path it'll fetch
    # the JSON from when the preset is pressed.
    name_xml=$(xml_escape "$body_name")
    location="/v1/playback/station/${body_id}"
    # containerArt is optional. We only include it when the SPA passed
    # an http(s) URL — otherwise the speaker would store the literal
    # placeholder text and the SoundTouch app would render a broken
    # image. Omitting the element keeps the speaker's existing art (or
    # nothing) instead of clobbering it.
    art_xml=""
    case "$body_art" in
        http://*|https://*)
            art_xml="<containerArt>$(xml_escape "$body_art")</containerArt>"
            ;;
    esac
    sp_body="<preset id=\"${body_slot}\"><ContentItem source=\"TUNEIN\" type=\"stationurl\" location=\"${location}\" sourceAccount=\"\" isPresetable=\"true\"><itemName>${name_xml}</itemName>${art_xml}</ContentItem></preset>"

    sp_url="${PLAYBACK_SPEAKER_BASE}/storePreset?id=${body_slot}"
    sp_body_file="$PLAYBACK_TMPDIR/presets-sp.$$.body"
    sp_resp_file="$PLAYBACK_TMPDIR/presets-sp.$$.resp"
    printf '%s' "$sp_body" >"$sp_body_file"

    # busybox wget on this firmware is GET-only — it doesn't accept
    # --post-file / --post-data, so we use curl (also installed at
    # /usr/bin/curl). curl writes the upstream HTTP status via -w; we
    # treat 000 (transport failure) and any 4xx/5xx as a failure.
    # Additionally inspect the response body because the speaker
    # sometimes returns 200 with an <errors><error>...</error> payload.
    sp_ok=1
    sp_status=$(/usr/bin/curl -s -o "$sp_resp_file" -w '%{http_code}' \
        -X POST -H 'Content-Type: application/xml' \
        --data-binary "@$sp_body_file" \
        "$sp_url")
    if [ -z "$sp_status" ] || [ "$sp_status" = "000" ]; then
        sp_ok=0
    elif [ "$sp_status" -ge 400 ] 2>/dev/null; then
        sp_ok=0
    fi
    if grep -q '<error' "$sp_resp_file" 2>/dev/null; then
        sp_ok=0
    fi

    if [ "$sp_ok" -eq 0 ]; then
        # Pull a human message from the response body if we got one.
        sp_err=$(tr '\n' ' ' <"$sp_resp_file" | xml_text error)
        if [ -z "$sp_err" ]; then
            sp_err="speaker rejected storePreset"
        fi
        rm -f "$sp_body_file" "$sp_resp_file"
        emit_error '502 Bad Gateway' STOREPRESET_REJECTED "$sp_err"
        return 0
    fi
    rm -f "$sp_body_file" "$sp_resp_file"

    # Success — return the now-current full presets list.
    if fetch_and_emit_presets >"$PLAYBACK_TMPDIR/presets-out.$$"; then
        emit_ok_headers 'GET, POST, OPTIONS'
        cat "$PLAYBACK_TMPDIR/presets-out.$$"
        rm -f "$PLAYBACK_TMPDIR/presets-out.$$"
    else
        rm -f "$PLAYBACK_TMPDIR/presets-out.$$"
        # storePreset succeeded but the follow-up GET failed. Surface
        # this distinctly so the browser knows to refetch later.
        emit_error '502 Bad Gateway' UPSTREAM_UNREACHABLE \
            "saved, but couldn't refetch presets list"
    fi
}

case "${REQUEST_METHOD:-GET}" in
    GET)  handle_get ;;
    POST) handle_post ;;
    *)
        emit_error '405 Method Not Allowed' METHOD_NOT_ALLOWED \
            "presets accepts GET and POST only"
        ;;
esac
