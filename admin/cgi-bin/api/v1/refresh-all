#!/bin/sh
#
# refresh-all — bulk re-probe TuneIn for each preset slot and atomically
# rewrite the resolver JSON whenever the playable stream URL list has
# drifted from what's on disk.
#
# POST /cgi-bin/api/v1/refresh-all → 200
#   {"ok":true,"data":{"updated":[...sid...],"unchanged":[...sid...],"failed":[{"sid":..,"error":..},...]}}
#
# Per-slot pipeline:
#   1. Read the slot's location from /presets (localhost:8090).
#   2. Pull the resolver JSON at $RESOLVER_DIR/<sid>.
#   3. Probe TuneIn (Tune.ashx) for the same sid via /usr/bin/curl.
#   4. Diff the streamUrl list. Same → unchanged.
#   5. Different → rebuild the Bose-shape JSON in awk and atomically
#      replace the on-disk file (tmp + mv on the same fs).
#
# We DO NOT call /storePreset. Each preset's location stays at
# /v1/playback/station/<sid>; the speaker fetches the rewritten
# resolver JSON on the next playback resolve, so the stream URLs land
# without disturbing slot metadata. See issue #44 for the rationale.
#
# Drift between the JSON shape this CGI emits and resolver/build.py's
# make_bose() / app/reshape.js is caught by the shared fixture suite
# at admin/test/fixtures/ — that's why those three implementations
# look interchangeable.
#
# busybox-shell only — no bash-isms, no jq, no python (Bo's firmware
# has none). Must pass shellcheck --severity=warning.

set -u

# shellcheck source=../../lib/cgi-common.sh
. "$(dirname "$0")/../../lib/cgi-common.sh"

SPEAKER_BASE='http://localhost:8090'
RESOLVER_DIR='/mnt/nv/resolver/bmx/tunein/v1/playback/station'
TUNEIN_BASE='http://opml.radiotime.com'
TUNEIN_MAGIC='formats=mp3,aac&lang=de-de&render=json'
UA='Bose_Lisa/27.0.6'
TMPDIR_FALLBACK="${TMPDIR:-/tmp}"

if [ "${REQUEST_METHOD:-GET}" = 'OPTIONS' ]; then
    printf 'Status: 204 No Content\r\n'
    printf 'Access-Control-Allow-Origin: *\r\n'
    printf 'Access-Control-Allow-Methods: POST, OPTIONS\r\n'
    printf 'Access-Control-Allow-Headers: Content-Type\r\n'
    printf '\r\n'
    exit 0
fi

case "${REQUEST_METHOD:-GET}" in
    POST) ;;
    *) emit_error '405 Method Not Allowed' METHOD_NOT_ALLOWED 'POST only'; exit 0 ;;
esac

WORK="$TMPDIR_FALLBACK/refresh-all.$$"
mkdir -p "$WORK" 2>/dev/null || {
    emit_error '500 Internal Server Error' WORKDIR_FAILED \
        'cannot create temp work dir'
    exit 0
}
trap 'rm -rf "$WORK"' EXIT INT TERM

# Fetch /presets and pull each slot's sid (the trailing s\d+ on the
# ContentItem location). Empty slots emit an empty line — caller
# treats that as "skip".
PRESETS_FILE="$WORK/presets.xml"
if ! curl -sf -o "$PRESETS_FILE" "$SPEAKER_BASE/presets"; then
    emit_error '502 Bad Gateway' UPSTREAM_UNREACHABLE \
        'speaker /presets fetch failed'
    exit 0
fi

# Per-slot sid list (1..6, one line per slot, blank when empty).
SIDS_FILE="$WORK/sids"
tr '\n' ' ' <"$PRESETS_FILE" | awk '
    function attr(s, tag, name,    re, rest, end) {
        re = "<" tag "[^>]* " name "=\""
        if (match(s, re) == 0) return ""
        rest = substr(s, RSTART + RLENGTH)
        end = index(rest, "\"")
        if (end == 0) return ""
        return substr(rest, 1, end - 1)
    }
    {
        body = $0
        for (n = 1; n <= 6; n++) {
            pat = "<preset id=\"" n "\""
            start = index(body, pat)
            if (start == 0) { print ""; continue }
            rest = substr(body, start)
            end = index(rest, "</preset>")
            if (end == 0) { print ""; continue }
            block = substr(rest, 1, end + length("</preset>") - 1)
            loc = attr(block, "ContentItem", "location")
            sid = ""
            if (match(loc, /\/station\/s[0-9]+$/)) {
                sid = substr(loc, RSTART + length("/station/"))
            }
            print sid
        }
    }
' >"$SIDS_FILE"

# Lists accumulate as space-separated sids (updated, unchanged) and as
# newline-delimited "sid<TAB>error" pairs (failed). They're awk-encoded
# into the response envelope at the end.
UPDATED=""
UNCHANGED=""
FAIL_FILE="$WORK/failed"
: >"$FAIL_FILE"

# Extract the ordered list of streamUrl values from a Bose-shape
# resolver JSON file on disk. Output is one URL per line. Robust
# against both make_bose's compact form and pretty-printed JSON.
extract_disk_streams() {
    awk '
        BEGIN { in_streams = 0; depth = 0 }
        {
            line = $0
            for (i = 1; i <= length(line); i++) {
                c = substr(line, i, 1)
                if (!in_streams) {
                    buf = buf c
                    if (length(buf) > 4096) buf = substr(buf, length(buf) - 4096)
                    if (match(buf, /"streams"[ \t\r\n]*:[ \t\r\n]*\[/)) {
                        in_streams = 1
                        depth = 1
                        buf = ""
                    }
                } else {
                    if (c == "[") depth++
                    else if (c == "]") {
                        depth--
                        if (depth == 0) exit
                    }
                    line2 = line2 c
                }
            }
        }
        END {
            # Walk the captured streams[] array and emit each streamUrl
            # value in source order.
            s = line2
            n = length(s)
            i = 1
            while (i <= n) {
                if (substr(s, i, 11) == "\"streamUrl\"") {
                    j = i + 11
                    while (j <= n && substr(s, j, 1) != ":") j++
                    j++
                    while (j <= n && substr(s, j, 1) != "\"") j++
                    j++
                    url = ""
                    while (j <= n && substr(s, j, 1) != "\"") {
                        url = url substr(s, j, 1)
                        j++
                    }
                    print url
                    i = j + 1
                } else {
                    i++
                }
            }
        }
    ' "$1" 2>/dev/null
}

# Pull the value of the on-disk JSON's top-level "name" field, so a
# rewrite preserves the friendly station name without re-parsing the
# /presets XML.
extract_disk_name() {
    awk '
        {
            line = line $0 " "
        }
        END {
            if (match(line, /"name"[ \t\r\n]*:[ \t\r\n]*"/)) {
                rest = substr(line, RSTART + RLENGTH)
                end = index(rest, "\"")
                if (end > 0) print substr(rest, 1, end - 1)
            }
        }
    ' "$1" 2>/dev/null
}

# Extract the playable stream URLs from a TuneIn Tune.ashx response.
# Mirrors make_bose()'s filter: drop empty URLs and any URL containing
# "notcompatible" (TuneIn's gated-station sentinel).
extract_tunein_streams() {
    awk '
        {
            buf = buf $0 " "
        }
        END {
            n = length(buf)
            i = 1
            while (i <= n) {
                if (substr(buf, i, 5) == "\"url\"") {
                    j = i + 5
                    while (j <= n && substr(buf, j, 1) != ":") j++
                    j++
                    while (j <= n && substr(buf, j, 1) != "\"") j++
                    j++
                    url = ""
                    while (j <= n && substr(buf, j, 1) != "\"") {
                        url = url substr(buf, j, 1)
                        j++
                    }
                    if (url != "" && index(url, "notcompatible") == 0) {
                        print url
                    }
                    i = j + 1
                } else {
                    i++
                }
            }
        }
    ' "$1" 2>/dev/null
}

# Build the Bose-shape resolver JSON for a station, given:
#   $1: sid (e.g. s17490)
#   $2: friendly name (already JSON-safe — no quotes/backslashes)
#   $3: path to a file containing one streamUrl per line
# Output goes to stdout. Mirrors resolver/build.py:make_bose().
emit_bose_json() {
    em_sid="$1"
    em_name="$2"
    em_streams_file="$3"

    # Escape the friendly name for inclusion in a JSON string literal.
    em_name_j=$(printf '%s' "$em_name" \
        | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' \
        | tr '\n' ' ' \
        | tr '\r' ' ' \
        | tr '\t' ' ')

    # First URL (top-level audio.streamUrl mirrors make_bose: it points
    # at the first compatible stream, used as the fallback when nothing
    # else in audio.streams is reachable).
    em_first=$(head -n 1 "$em_streams_file")

    awk -v sid="$em_sid" -v name="$em_name_j" -v first="$em_first" '
        function jesc(s,    i, n, c, out) {
            out = ""; n = length(s)
            for (i = 1; i <= n; i++) {
                c = substr(s, i, 1)
                if (c == "\\")      out = out "\\\\"
                else if (c == "\"") out = out "\\\""
                else if (c == "\n") out = out "\\n"
                else if (c == "\r") out = out "\\r"
                else if (c == "\t") out = out "\\t"
                else                out = out c
            }
            return out
        }
        BEGIN {
            printf "{\"_links\":{"
            printf "\"bmx_reporting\":{\"href\":\"/v1/report?stream_id=e0&guide_id=%s&listen_id=0&stream_type=liveRadio\"},", sid
            printf "\"bmx_favorite\":{\"href\":\"/v1/favorite/%s\"},", sid
            printf "\"bmx_nowplaying\":{\"href\":\"/v1/now-playing/station/%s\",\"useInternalClient\":\"ALWAYS\"}", sid
            printf "},"
            printf "\"audio\":{"
            printf "\"hasPlaylist\":true,"
            printf "\"isRealtime\":true,"
            printf "\"maxTimeout\":60,"
            printf "\"streamUrl\":\"%s\",", jesc(first)
            printf "\"streams\":["
            sep = ""
        }
        {
            printf "%s{\"bufferingTimeout\":20,\"connectingTimeout\":10,\"hasPlaylist\":true,\"isRealtime\":true,\"streamUrl\":\"%s\",\"maxTimeout\":60}", sep, jesc($0)
            sep = ","
        }
        END {
            printf "]},"
            printf "\"imageUrl\":\"\","
            printf "\"isFavorite\":false,"
            printf "\"name\":\"%s\",", name
            printf "\"streamType\":\"liveRadio\""
            printf "}"
        }
    ' "$em_streams_file"
}

slot=0
while IFS= read -r sid; do
    slot=$((slot + 1))
    [ -z "$sid" ] && continue

    # Fetch the TuneIn probe. curl exits nonzero on transport / 4xx.
    tunein_file="$WORK/$sid.tunein"
    if ! curl -sf -A "$UA" -o "$tunein_file" \
            "$TUNEIN_BASE/Tune.ashx?$TUNEIN_MAGIC&id=$sid"; then
        printf '%s\ttunein probe failed\n' "$sid" >>"$FAIL_FILE"
        continue
    fi

    new_streams="$WORK/$sid.new"
    extract_tunein_streams "$tunein_file" >"$new_streams"
    if [ ! -s "$new_streams" ]; then
        printf '%s\tno compatible streams in TuneIn response\n' "$sid" >>"$FAIL_FILE"
        continue
    fi

    disk_path="$RESOLVER_DIR/$sid"
    disk_streams="$WORK/$sid.disk"
    : >"$disk_streams"
    if [ -r "$disk_path" ]; then
        extract_disk_streams "$disk_path" >"$disk_streams"
    fi

    if cmp -s "$disk_streams" "$new_streams"; then
        UNCHANGED="$UNCHANGED $sid"
        continue
    fi

    # Rewrite. Atomic: tmp file in the same dir + mv.
    name=$(extract_disk_name "$disk_path")
    [ -z "$name" ] && name="$sid"
    new_json="$WORK/$sid.json"
    if ! emit_bose_json "$sid" "$name" "$new_streams" >"$new_json"; then
        printf '%s\tbuild failed\n' "$sid" >>"$FAIL_FILE"
        continue
    fi

    target_tmp="$disk_path.tmp"
    if ! cp "$new_json" "$target_tmp" 2>/dev/null; then
        printf '%s\twrite failed\n' "$sid" >>"$FAIL_FILE"
        continue
    fi
    if ! mv "$target_tmp" "$disk_path" 2>/dev/null; then
        rm -f "$target_tmp"
        printf '%s\trename failed\n' "$sid" >>"$FAIL_FILE"
        continue
    fi
    UPDATED="$UPDATED $sid"
done <"$SIDS_FILE"

emit_ok_headers
{
    printf '{"ok":true,"data":{'

    printf '"updated":['
    sep=""
    for s in $UPDATED; do
        printf '%s"%s"' "$sep" "$s"
        sep=","
    done
    printf '],'

    printf '"unchanged":['
    sep=""
    for s in $UNCHANGED; do
        printf '%s"%s"' "$sep" "$s"
        sep=","
    done
    printf '],'

    printf '"failed":['
    awk '
        function jesc(s,    i, n, c, out) {
            out = ""; n = length(s)
            for (i = 1; i <= n; i++) {
                c = substr(s, i, 1)
                if (c == "\\")      out = out "\\\\"
                else if (c == "\"") out = out "\\\""
                else                out = out c
            }
            return out
        }
        BEGIN { FS = "\t"; sep = "" }
        NF >= 2 {
            printf "%s{\"sid\":\"%s\",\"error\":\"%s\"}", sep, jesc($1), jesc($2)
            sep = ","
        }
    ' "$FAIL_FILE"
    printf ']'

    printf '}}\n'
}
