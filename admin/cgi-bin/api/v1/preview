#!/bin/sh
#
# preview — write the chosen Bose JSON for a station and tell Bo to
# play it right now via /select. Used by the station-detail audition
# button: the user picks a stream, clicks ▶, and this endpoint stages
# the URL on disk and tunes the speaker to it.
#
# Body (JSON): { "id": "sNNN", "name": "...", "json": { ... } }
#
# Side effect: the resolver entry at
# /mnt/nv/resolver/bmx/tunein/v1/playback/station/<id> is REPLACED
# atomically. If a preset already points at this id, its next press
# uses the previewed URL — same station, possibly different stream.
# That's intentional: the next "Set as preset" click writes the same
# JSON anyway, so leaving the previewed copy in place is consistent.
#
# Envelope: `{ ok:false, error: { code:"SHOUTY", message:"..." } }`.
# See admin/cgi-bin/lib/playback.sh for the helpers and CSRF guard
# shared with /play and /presets.
#
# busybox-shell only — no bash-isms. Uses /usr/bin/curl for the
# /select POST (busybox wget is GET-only).

set -u

# shellcheck source=../../lib/playback.sh
. "$(dirname "$0")/../../lib/playback.sh"

# CORS preflight — answer and exit before any work.
if handle_cors_preflight 'POST, OPTIONS'; then exit 0; fi

case "${REQUEST_METHOD:-GET}" in
    POST) ;;
    *)
        emit_error '405 Method Not Allowed' METHOD_NOT_ALLOWED \
            'POST only'
        exit 0
        ;;
esac

# Same Origin+Referer guard as the speaker CGI.
csrf_guard || exit 0

# Slurp the request body to a tempfile.
body_file="$PLAYBACK_TMPDIR/preview.$$.body"
trap 'rm -f "$body_file" "$body_file.json.tmp" "$body_file.sp.resp"' EXIT INT TERM
slurp_body "$body_file"

body_id=$(json_string_field id <"$body_file")
body_name=$(json_string_field name <"$body_file")
body_json=$(json_object_field <"$body_file")

# Validate id like the presets CGI does.
case "$body_id" in
    s[0-9]*) ;;
    *)
        emit_error '400 Bad Request' INVALID_ID \
            "id must match ^s[0-9]+\$"
        exit 0
        ;;
esac
if [ -z "$body_name" ]; then
    emit_error '400 Bad Request' INVALID_NAME 'name must be non-empty'
    exit 0
fi
if [ -z "$body_json" ]; then
    emit_error '400 Bad Request' INVALID_JSON 'json field missing'
    exit 0
fi

# Atomic write: tmp file beside the destination, then mv.
target="$PLAYBACK_RESOLVER_DIR/$body_id"
tmp="$target.tmp"
mkdir -p "$PLAYBACK_RESOLVER_DIR" 2>/dev/null
if ! printf '%s' "$body_json" >"$tmp" 2>/dev/null; then
    emit_error '500 Internal Server Error' WRITE_FAILED 'tmp write failed'
    exit 0
fi
if ! mv "$tmp" "$target" 2>/dev/null; then
    rm -f "$tmp"
    emit_error '500 Internal Server Error' RENAME_FAILED 'rename failed'
    exit 0
fi

# POST a <ContentItem> to /select. The speaker fetches the resolver
# JSON for this id (which we just rewrote) and starts playing.
name_xml=$(xml_escape "$body_name")
sp_body=$(build_content_item "$body_id" "$name_xml")
sp_resp_file="$body_file.sp.resp"
sp_status=$(select_post "$sp_body" "$sp_resp_file")

if select_failed_check "$sp_status" "$sp_resp_file"; then
    emit_error '502 Bad Gateway' SELECT_REJECTED \
        "speaker /select failed (HTTP $sp_status)"
    exit 0
fi

emit_ok_empty 'POST, OPTIONS'
